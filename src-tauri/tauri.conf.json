{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CC Launcher",
  "version": "0.1.0",
  "identifier": "com.cc-launcher.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "CC Launcher",
        "width": 520,
        "height": 480,
        "resizable": true,
        "center": true,
        "transparent": false,
        "decorations": true,
        "minWidth": 380,
        "minHeight": 300,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data: https://fonts.gstatic.com; style-src-elem 'self' 'unsafe-inline' https://fonts.googleapis.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
